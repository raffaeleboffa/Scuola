# Configurazione Database
# Configura queste caratteristiche in base al tuo ambiente di sviluppo.

# DBMS: mysql, sqlite
DBMS=mysql

# ==================

# Se stai usando SQLite, specifica il percorso del file del database. Assicurati che il file esista e sia accessibile.
# DB_FILE_PATH=database/database.sqlite

# ==================

DB_HOST=localhost
DB_PORT=3306

# ==================

DB_USERNAME=root
DB_PASSWORD=

# ==================

DB_NAME=boffaPHPFrameworkDB